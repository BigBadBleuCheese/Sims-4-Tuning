<?xml version="1.0" encoding="utf-8"?>
<I c="Tutorial" i="tutorial" m="tutorials.tutorial" n="tutorial_EP20_AdventureAwaits_ButterflyCollection" s="484089">
  <T n="category">481599<!--TutorialCategory: tutorial_Category_AdventureAwaits--></T>
  <T n="name">0xC1BC3679<!--String: "Butterflies and Moths Collection"--></T>
  <L n="slides">
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_ButterflyCollection_1.png">2f7d0004:00000000:1f1b076b052bdd44</T>
      <T n="text">0x939C2B7F<!--String: "There are multiple ways to interact with <font color="#199C2C"><b>Butterflies and Moths</b></font> in Gibbi Point. You can catch Butterflies and Moths around the world and can even <font color="#199C2C"><b>Raise a Butterfly or Moth</b></font> in a <font color="#199C2C"><b>Caterpillar Incubator</b></font>. To learn more about captured Butterflies and Moths, you can <font color="#199C2C"><b>Place in World</b></font> from the <font color="#199C2C"><b>Sim Inventory</b></font> and <font color="#199C2C"><b>Examine</b></font>. You can place Butterflies and Moths into the <font color="#199C2C"><b>Butterfly Habitat</b></font> or <font color="#199C2C"><b>Rehome</b></font> them into the <font color="#199C2C"><b>Butterfly Topiaries</b></font> around Gibbi Point."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_ButterflyCollection_2.png">2f7d0004:00000000:1f1b076b052bdd47</T>
      <T n="text">0x48A25DA1<!--String: "Butterflies and Moths can be found all round Gibbi Point! Butterflies are visible during daylight hours and Moths only come out at night. There are also a few special Butterflies and Moths that are found during Gibbi Point Festivals and by interacting with other activities within the world."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_ButterflyCollection_3.png">2f7d0004:00000000:1f1b076b052bdd46</T>
      <T n="text">0xE95BC20F<!--String: "To view hints on where to find specific Butterflies or Moths, select the <font color="#199C2C"><b>Household Collections</b></font> button found in the upper right corner of the <font color="#199C2C"><b>Sim Inventory</b></font> to bring up the <font color="#199C2C"><b>Household Collections UI</b></font>. Choose the <font color="#199C2C"><b>Gibbi Point Butterflies and Moths Collection</b></font>. Here you'll be able to find hints for each of the collectables by hovering over the icons."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_ButterflyCollection_4.png">2f7d0004:00000000:1f1b076b052bdd41</T>
      <T n="text">0x1B528F9E<!--String: "If you'd like to <font color="#199C2C"><b>Hatch a Butterfly or Moth</b></font> on your own, purchase a <font color="#199C2C"><b>Flutterarium Caterpillar Incubator</b></font> in Build Mode. Interact to Raise a Butterfly or Moth from a caterpillar. Raising it will increase a Sim's <font color="#199C2C"><b>Entomology Skill</b></font>, and increasing this Skill will allow the Sim to raise different types of butterflies and moths."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_ButterflyCollection_5.png">2f7d0004:00000000:1f1b076b052bdd40</T>
      <T n="text">0xFEF18772<!--String: "The <font color="#199C2C"><b>Butterfly Habitat</b></font> supports one Butterfly of each type. It's the perfect place for Butterflies and Moths to thrive! You can also purchase a <font color="#199C2C"><b>Caterpillar Incubator</b></font> from the Butterfly Habitat and <font color="#199C2C"><b>Enable Emotional Aura</b></font>."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_ButterflyCollection_6.png">2f7d0004:00000000:1f1b076b052bdd43</T>
      <T n="text">0x7A719DD<!--String: "When collecting each Butterfly or Moth, as a bonus, each Butterfly or Moth is unlocked as a <font color="#199C2C"><b>Placeable Effect</b></font>. It can be found in <font color="#199C2C"><b>Build Mode</b></font>. Once all of the Gibbi Point Butterflies and Moths have been collected, you can now select the Butterfly Habitat to <font color="#199C2C"><b>Disable Unique Butterfly & Moth Restrictions</b></font>. This means that the Butterfly Habitat is no longer restricted to one Butterfly and Moth of each type."--></T>
    </U>
  </L>
  <L n="tags">
    <E>Lesson_EP20_AdventureAwaits</E>
  </L>
  <T n="ui_sort_order">4</T>
</I>