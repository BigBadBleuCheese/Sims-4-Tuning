<I c="Tutorial" i="tutorial" m="tutorials.tutorial" n="tutorial_EP20_AdventureAwaits_FormativeMoments" s="485176">
  <T n="category">481599<!--TutorialCategory: tutorial_Category_AdventureAwaits--></T>
  <T n="name">0x2B323BF8<!--String: "Formative Moments"--></T>
  <L n="slides">
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_FormativeMoments_1.png">2f7d0004:00000000:45d98c371962f707</T>
      <T n="text">0xF3C56B1B<!--String: "Formative Moments are goal-based challenges that your child Sim discovers as they explore and interact with the world and other Sims. Suggested Challenges can be made Active, and completing Active Challenges gives Reward Traits that confer bonuses when your child Sim grows up to be a Teen and beyond!"--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_FormativeMoments_2.png">2f7d0004:00000000:45d98c371962f704</T>
      <T n="text">0xC81495E1<!--String: "If your Sim needs some inspiration, just select the <font color="#199C2C"><b>Take on a Formative Challenge</b></font> interaction on themselves. There is a limit to how many Suggested or Active Challenges are available for your Sim, but Challenges can be discarded at any time."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_FormativeMoments_3.png">2f7d0004:00000000:45d98c371962f705</T>
      <T n="text">0xF3882D6E<!--String: "Don't worry if your adult Sim missed out on Formative Moments! The Reward Traits can be purchased from the Reward Store, or a free one can be obtained by <font color="#199C2C"><b>Recall a Lost Formative Moment</b></font> on your adult Sim. A phone call from a friend, or nearby child Sims may also cause a Sim to <font color="#199C2C"><b>Recall a Lost Formative Moment</b></font>."--></T>
    </U>
  </L>
  <L n="tags">
    <E>Lesson_EP20_AdventureAwaits</E>
  </L>
