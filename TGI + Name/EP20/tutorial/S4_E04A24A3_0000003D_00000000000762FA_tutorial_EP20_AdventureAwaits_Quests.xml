<?xml version="1.0" encoding="utf-8"?>
<I c="Tutorial" i="tutorial" m="tutorials.tutorial" n="tutorial_EP20_AdventureAwaits_Quests" s="484090">
  <T n="category">481599<!--TutorialCategory: tutorial_Category_AdventureAwaits--></T>
  <T n="name">0x1E0418DD<!--String: "Gibbi Point Locals"--></T>
  <L n="slides">
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_Quests_1.png">2f7d0004:00000000:58b32ddcddb52d5e</T>
      <T n="text">0x1221F844<!--String: "Gibbi Point is home to vibrant locals who immerse visitors in exploration and storytelling through <font color="#199C2C"><b>Adventure Quests</b></font>.\n\nTo learn about Gibbi Point Quests, locate the <font color="#199C2C"><b>Adventure Story Map</b></font> in the town square of <font color="#199C2C"><b>Jellyfish Junction</b></font>. Select the Story Map and <font color="#199C2C"><b>Learn about Gibbi Point Quests</b></font>."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_Quests_2.png">2f7d0004:00000000:58b32ddcddb52d5d</T>
      <T n="text">0x5A8B982F<!--String: "To get to know Gibbi Point and the secrets the region holds, catch up with Toshie, famed <font color="#199C2C"><b>Storyteller</b></font> in Jellyfish Junction. <font color="#199C2C"><b>Inquire about Adventure Quests</b></font> to embark on a fun adventure learning about <font color="#199C2C"><b>The Great Adventurers</b></font>, a childhood group that began many years ago with Toshie, Nigel, and Raheel, also known as <font color="#199C2C"><b>The Lost Adventurer</b></font>."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_Quests_3.png">2f7d0004:00000000:58b32ddcddb52d5c</T>
      <T n="text">0x20D086F1<!--String: "You can find the <font color="#199C2C"><b>Butterfly Conservationist</b></font>, Laxmi in Wanderwood Wilds near the <font color="#199C2C"><b>Butterfly Ranger Station</b></font>. <font color="#199C2C"><b>Inquire about Adventure Quests</b></font> to <font color="#199C2C"><b>Raise a Butterfly</b></font> in an incubator as a guided quest. Laxmi is the sibling of the <font color="#199C2C"><b>Lost Adventurer</b></font>, Raheel, and can often be found chatting with him around the campfire."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_Quests_4.png">2f7d0004:00000000:58b32ddcddb52d5b</T>
      <T n="text">0x7997D85F<!--String: "If you have some collectibles and you'd like to trade them, find Buddy Scoop, Crystal Valley's own <font color="#199C2C"><b>Collector Kid</b></font>! You can find him near <font color="#199C2C"><b>Scoop's Mine</b></font> daily between 10AM - 8PM."--></T>
    </U>
    <U>
      <T n="image" p="InEP20\UI\Lessons\EP20_Quests_5.png">2f7d0004:00000000:58b32ddcddb52d5a</T>
      <T n="text">0xC3FC1E30<!--String: "The most unusual of <font color="#199C2C"><b>Gibbi Point Locals</b></font> is the mysterious <font color="#199C2C"><b>Pruella Preener</b></font>, the region's own <font color="#199C2C"><b>Plumbird</b></font> Sim. Learn about her by completing Quests about <font color="#199C2C"><b>Plumbird Lore</b></font>. You can begin these quests by selecting either the <font color="#199C2C"><b>Plumbird Nest</b></font> in Crystal Valley or the <font color="#199C2C"><b>Adventure Story Map</b></font> in Jellyfish Junction."--></T>
    </U>
  </L>
  <L n="tags">
    <E>Lesson_EP20_AdventureAwaits</E>
  </L>
  <T n="ui_sort_order">3</T>
</I>